# ─────────────────────────────────────────────────────────────
# Medium MCP — Environment Configuration
# Copy to `.env` and fill in your values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Publishing is browser-based. Medium stopped issuing new API integration
# tokens, so this server drives the real Medium web editor via a browser.
# There is NO token to configure — instead:
#
#   1. npm run install:browser      # one-time: download the Chromium binary
#   2. run the `medium_login` tool  # a browser window opens; sign in once
#
# Your session is saved to disk (MEDIUM_SESSION_DIR) and reused headlessly.

# Optional: where the persisted login session lives.
# Defaults to `<MEDIUM_DATA_DIR>/browser-profile`.
MEDIUM_SESSION_DIR=

# Optional: run the browser headless when publishing (true|false).
# The `medium_login` tool always opens a visible window regardless of this.
MEDIUM_HEADLESS=true

# Optional: per-action browser timeout in milliseconds.
MEDIUM_BROWSER_TIMEOUT=30000

# Optional: default publishing behavior
MEDIUM_DEFAULT_PUBLICATION=
MEDIUM_DEFAULT_TAGS=
MEDIUM_DEFAULT_VISIBILITY=public

# Optional: writing defaults
MEDIUM_WRITING_TONE=professional
MEDIUM_WRITING_LANGUAGE=en
MEDIUM_DEFAULT_MODEL=claude-opus-4-8

# Optional: autosave interval (ms) and local data directory
MEDIUM_AUTOSAVE_INTERVAL=30000
MEDIUM_DATA_DIR=.medium-mcp

# Optional: research provider (tavily | brave | perplexity | firecrawl | none)
MEDIUM_RESEARCH_PROVIDER=none
TAVILY_API_KEY=
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
FIRECRAWL_API_KEY=

# Optional: logging (error | warn | info | debug) and verbose flag
MEDIUM_LOG_LEVEL=info
MEDIUM_VERBOSE=false
