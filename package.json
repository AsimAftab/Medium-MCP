{
  "name": "medium-mcp",
  "version": "1.0.0",
  "description": "Production-grade Model Context Protocol server for researching, generating, editing, optimizing, scheduling, and publishing Medium articles from natural language.",
  "type": "module",
  "license": "MIT",
  "author": "medium-mcp contributors",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "medium",
    "blogging",
    "ai",
    "content",
    "writing",
    "seo",
    "claude"
  ],
  "bin": {
    "medium-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "install:browser": "playwright install chromium",
    "login": "tsx src/cli/login.ts",
    "session": "tsx src/cli/status.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "markdown-it": "^14.1.0",
    "playwright": "^1.49.1",
    "turndown": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.5",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
